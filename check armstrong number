#include <iostream>
using namespace std;

int main() {
    int num, temp, sum = 0;
    cin >> num;
    temp = num;

    while(temp > 0) {
        int d = temp % 10;
        sum += d * d * d;
        temp /= 10;
    }

    if(sum == num)
        cout << "Armstrong";
    else
        cout << "Not Armstrong";

    return 0;
}
