#include <iostream>
using namespace std;

int main() {
    int n, i = 2;
    bool isPrime = true;
    cin >> n;

    while(i <= n/2) {
        if(n % i == 0) {
            isPrime = false;
            break;
        }
        i++;
    }

    if(isPrime && n > 1)
        cout << "Prime";
    else
        cout << "Not Prime";

    return 0;
}
