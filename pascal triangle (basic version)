#include <iostream>
using namespace std;

long long fact(int n) {
    long long res = 1;
    while(n > 1)
        res *= n--;
    return res;
}

int main() {
    int n;
    cin >> n;

    for(int i = 0; i < n; i++) {
        for(int j = 0; j <= i; j++)
            cout << fact(i) / (fact(j) * fact(i - j)) << " ";
        cout << endl;
    }

    return 0;
}
